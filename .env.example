# =====================================================================
# NEXLORA — Environment variables
# Copy this file to `.env.local` and fill in real values for local dev.
# In production, set these in your hosting provider (Vercel, etc.).
# =====================================================================

# --- PUBLIC (exposed to browser, must start with NEXT_PUBLIC_) -------

# Canonical site URL — used for sitemap, OG tags, JSON-LD.
NEXT_PUBLIC_SITE_URL=https://nexlora.com

# Calendly link for "Book a Discovery Call" CTA.
# If unset, the contact page is used as fallback.
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/nexlora/discovery

# Plausible Analytics domain. Optional — analytics only loads if set
# AND user has accepted cookies. Leave blank for no analytics.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# --- PRIVATE (server-only) ------------------------------------------

# Anthropic API key for the chat widget.
# If unset, chat falls back to an expanded keyword-matching reply set.
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Resend API key for the contact form.
# If unset, form submissions are logged to the server console (dev mode).
# Get one at: https://resend.com
RESEND_API_KEY=

# Address email is sent FROM. Must be a verified Resend sender domain.
# For first run with Resend, you can use their onboarding sandbox:
#   onboarding@resend.dev
RESEND_FROM_EMAIL="Nexlora <hello@nexlora.com>"

# Address contact-form submissions are delivered TO.
CONTACT_TO_EMAIL=hello@nexlora.com
